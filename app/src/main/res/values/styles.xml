<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SmallButtonTransparent" parent="@style/Widget.Material3.Button">
        <item name="android:backgroundTint">#7f7f7f7f</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">10sp</item>
<!--        <item name="android:background">@drawable/button_border_ripple</item>-->
    </style>

    <style name="SegmentedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/seg_stroke_color</item>
        <item name="android:textColor">@color/seg_text_color</item>

        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="elevation">0dp</item>

        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>

        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">8sp</item>

        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
</resources>